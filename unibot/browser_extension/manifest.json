{
  "manifest_version": 3,
  "name": "UniBot Guardian Mantel",
  "description": "Local Socratic practice overlay for Colab and Jupyter. Not an exam security guarantee.",
  "version": "0.3.0",
  "key": "",
  "permissions": ["activeTab", "nativeMessaging", "sidePanel"],
  "host_permissions": [
    "https://colab.research.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://colab.research.google.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "v2/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "UniBot Guardian"
  }
}
